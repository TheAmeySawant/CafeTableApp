# CLOUDFLARE D1 & KV
# These are configured in wrangler.toml, but if using local dev they use local SQLite files automatically.

# PUSHER API KEYS (Realtime)
NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_key
PUSHER_APP_ID=your_pusher_app_id
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_CLUSTER=ap2

# BREVO (Email OTP)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@yourcafe.com
BREVO_FROM_NAME="Cafe Team"

# JWT Auth Secret
JWT_SECRET=super_secret_for_local_dev_only

# BACKBLAZE B2 (Images)
B2_KEY_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_app_key
B2_BUCKET_NAME=your_b2_bucket_name
NEXT_PUBLIC_B2_ENDPOINT=https://your-bucket-name.s3.us-west-004.backblazeb2.com
