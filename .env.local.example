# ─────────────────────────────────────────────
# Café Management PWA – Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Cloudflare D1 / KV ───────────────────────
# D1 and KV are injected as Worker bindings via wrangler.toml.
# No env vars required here — configure database_id in wrangler.toml.

# ── JWT Auth ──────────────────────────────────
# Secret used to sign/verify session JWTs. Use a long random string.
JWT_SECRET="replace-with-a-very-long-random-secret"

# ── Pusher Channels (realtime) ────────────────
# Create a free Pusher Channels app at https://pusher.com
NEXT_PUBLIC_PUSHER_APP_KEY="your_pusher_app_key"
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_SECRET="your_pusher_secret"
PUSHER_CLUSTER="ap2"

# ── Brevo (email OTP) ─────────────────────────
# Create a free account at https://www.brevo.com (300 emails/day free)
BREVO_API_KEY="your_brevo_api_key"
BREVO_FROM_EMAIL="noreply@yourdomain.com"
BREVO_FROM_NAME="The Roasted Bean"

# ── Backblaze B2 (image storage) ──────────────
# Create a free B2 bucket at https://www.backblaze.com/b2/cloud-storage.html
# Use an Application Key (not the master key) scoped to your bucket.
B2_KEY_ID="your_b2_key_id"
B2_APPLICATION_KEY="your_b2_application_key"
B2_BUCKET_ID="your_b2_bucket_id"
# Public download URL (e.g. https://f005.backblazeb2.com/file/your-bucket-name)
NEXT_PUBLIC_B2_ENDPOINT="https://f005.backblazeb2.com/file/your-bucket-name"

# ── App URL (used for QR code generation) ─────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Dev Bypass (remove before production!) ────
# Set to "true" to skip auth middleware during local UI review.
# NEXT_PUBLIC_DEV_BYPASS=true
